    "allow_raw_dataset_reads": false,
    "allow_secret_reads": false,
    "allow_checkpoint_io": false,
    "allow_run_directory_io": false,
    "allow_remote_gpu": false,
    "allow_training": false,
    "allow_inference": false,
    "allow_evaluation": false,
    "allow_parser_construction": false,
    "allow_target_construction": false,
    "allow_split_or_view_construction": false,
    "allow_long_lived_server": false,
    "allow_public_tunnel": false,
    "allow_persisted_endpoint_or_token": false
  }
