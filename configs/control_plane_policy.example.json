{
  "version": "v1",
  "project_name": "<PROJECT_NAME>",
  "github_repository": "<OWNER>/<REPO>",
  "branch": "<BRANCH>",
  "fixed_chatgpt_conversation_id": "<FIXED_CHATGPT_CONVERSATION_ID>",
  "formal_review_authority": "fixed_chatgpt_web_github_exact_pushed_head",
